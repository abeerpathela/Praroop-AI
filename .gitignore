# Data artifacts (processed / results stay ignored)
data/processed/
data/results/
data/results/*.jpg

# Track small synthetic test assets under data/raw/
!data/raw/
!data/raw/README.md
!data/raw/*.jpg
!data/raw/forge_meta.json

# Track Praroop template JSON (not binary weights)
!data/templates/
!data/templates/*.json

# ELA temporary recompress artifacts
temp_resaved.jpg
**/temp_resaved.jpg

# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment / secrets (do not track)
.env
.env.*
*.env
.envrc
.venv/
venv/
env/
ENV/
.conda/
conda-env/
Pipfile.lock

# Streamlit secrets / local config
.streamlit/secrets.toml
.streamlit/config.toml
**/.streamlit/secrets.toml
**/.streamlit/config.toml

# Model weights (never commit trained / downloaded binaries)
*.pt
*.weights
models/*.pt
models/*.weights
models/**/*.pt
models/**/*.weights

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Testing / build
.pytest_cache/
*.egg-info/
dist/
build/
*.egg

# Scoring calibration / runtime logs
*.log
**/*.log
